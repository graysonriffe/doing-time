;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Clone Game"
config/description="You must create clones of yourself by recording your movements to move through and complete puzzles."
config/version="indev"
run/main_scene="uid://5komtf4y6gif"
config/use_custom_user_dir=true
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="res://assets/icon.svg"

[audio]

buses/default_bus_layout="uid://b8dufx07d2y3d"

[autoload]

MusicPlayer="*uid://e07415mkurns"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_position_type=4
window/stretch/mode="canvas_items"

